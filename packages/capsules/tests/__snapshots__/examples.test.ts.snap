// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`builtin examples > renders example template prompts (snapshots) > example-acceptance-criteria 1`] = `
"Generate clear, testable acceptance criteria for the request below.
Respond with JSON only:
{ "criteria": string[], "assumptions": string[] }

<acceptance_criteria>
Request:
Build a todo app with offline sync
</acceptance_criteria>"
`;

exports[`builtin examples > renders example template prompts (snapshots) > example-answer-verification 1`] = `
"Verify whether the candidate answer satisfies every acceptance criterion.
Respond with JSON only:
{ "passed": boolean, "failures": string[], "notes": string }

Acceptance criteria:
{
  "criteria": [
    "Supports add",
    "Works offline"
  ],
  "assumptions": []
}

Candidate answer:
The app stores todos locally and syncs when online."
`;

exports[`builtin examples > renders example template prompts (snapshots) > example-candidate-answer 1`] = `
"Write a complete candidate answer that satisfies the acceptance criteria.

