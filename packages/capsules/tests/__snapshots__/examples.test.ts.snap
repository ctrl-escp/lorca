`;

exports[`builtin examples > renders example template prompts (snapshots) > example-drift-check 1`] = `
"Compare baseline and current text. Detect meaning drift, omissions, or contradictions.
Respond with JSON only:
{ "drifted": boolean, "severity": "none" | "low" | "high", "differences": string[] }

Baseline:
The service returns 200 for healthy checks.

Current:
The service returns 503 for healthy checks."
`;

exports[`builtin examples > renders example template prompts (snapshots) > example-intent-extraction 1`] = `
