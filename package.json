{
  "name": "lorca",
  "private": true,
  "version": "0.0.1",
  "description": "Local AI Orchestrator — browser-first AI pipeline workbench",
  "engines": {
    "node": ">=24.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "eslint .",
    "build": "npm run build --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "npm run dev --workspace=apps/web",
    "validate": "npm run lint && npm run build && npm test"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^9.0.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
