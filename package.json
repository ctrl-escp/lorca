{
  "name": "lorca",
  "private": true,
  "version": "0.0.1",
  "description": "Local AI Orchestrator — browser-first AI pipeline workbench",
  "engines": {
    "node": ">=24.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "npx eslint --ignore-pattern 'apps/web/dist/**' --ignore-pattern '**/dist/**' --ignore-pattern '**/coverage/**' .",
    "build": "npm run build --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run test:e2e --workspace=apps/web",
    "dev": "npm run dev --workspace=apps/web",
    "validate": "npm run lint && npm run build && npm test"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^10.9.1",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "typescript": "^5.6.0",
    "vitest": "^4.1.6",
    "vue-eslint-parser": "^10.4.0"
  },
  "dependencies": {
    "dexie": "^4.4.2"
  }
}
